meta {
  name: 04 Me
  type: http
  seq: 4
}

get {
  url: {{baseUrl}}/me
  body: none
  auth: bearer
}

auth:bearer {
  token: {{authToken}}
}

tests {
  test("returns the authenticated self-hosted user", function () {
    expect(res.status).to.equal(201);
    expect(res.body.user.userId).to.equal(bru.getEnvVar("username"));
  });
}
